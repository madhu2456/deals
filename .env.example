# Local: relative SQLite file under prisma/
DATABASE_URL="file:./dev.db"
# Docker/production (volume at /app/data):
# DATABASE_URL="file:/app/data/deals.db"

# Admin credentials for the dashboard
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="change-me-in-production"
ADMIN_SECRET="replace-this-with-a-long-random-secret-at-least-32-chars"

# Canonical site URL (used in sitemap, robots, Open Graph, JSON-LD)
# Production: https://deals.madhudadi.in  |  Local: http://localhost:3000
NEXT_PUBLIC_SITE_URL="https://deals.madhudadi.in"

# Host port published by docker compose (default 3000)
# APP_PORT=3000

# Seed categories on container start (set false after first deploy)
# RUN_SEED=false

# Optional: Google Search Console verification meta content
# GOOGLE_SITE_VERIFICATION=""

